# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_engine_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# External API Keys
YOUTUBE_API_KEY=your_youtube_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional Settings
LOG_LEVEL=info

# ============================================
# PERFORMANCE SETTINGS (Optimized for speed)
# ============================================

# API Request Timeout (reduced from 30000 to 10000)
REQUEST_TIMEOUT=10000

# Reddit Settings (for parallel processing)
REDDIT_BATCH_SIZE=5           # Parallel subreddit searches (3-8)
REDDIT_MAX_SUBREDDITS=10      # Reduced from 15 for faster queries

# Source Limits (reduced for faster processing)
MAX_YOUTUBE_RESULTS=8         # Reduced from 10
MAX_REDDIT_RESULTS=15         # Reduced from 20
MAX_SOURCES_PER_QUERY=20

# Content Length (reduced for smaller AI prompts)
SOURCE_CONTENT_MAX_LENGTH=800 # Reduced from 1000

# Performance Presets:
# BALANCED (default): ~12-17 seconds - Use values above
# FAST: ~8-12 seconds - Set REDDIT_BATCH_SIZE=8, REDDIT_MAX_SUBREDDITS=8, MAX_YOUTUBE_RESULTS=6
# QUALITY: ~20-25 seconds - Set REDDIT_BATCH_SIZE=3, REDDIT_MAX_SUBREDDITS=15, MAX_YOUTUBE_RESULTS=10
